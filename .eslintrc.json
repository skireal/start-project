{ 
  "env": {
    "browser": true,
    "jquery": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "overrides": [
    {
      "files": [ "src/**/*.js" ],
      "extends": [
        "htmlacademy/es6"
      ],
      "rules": {
        "indent": [
          "error",
          4
        ],
        "semi": [
          "error",
          "never"
        ],
        "quotes": [2, "single", { "avoidEscape": true }],
        "eol-last": "off"
      }
    }
  ]
}